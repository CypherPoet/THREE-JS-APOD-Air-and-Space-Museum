# Local Claude state — ignore everything except the project skills.
# All skills under .claude/skills/ ship with the repo, so anyone who
# clones inherits the same developer-environment tooling.
.claude/*
!.claude/skills/

# macOS
.DS_Store

# Editor / IDE
.vscode/
*.swp
*.swo

# Node
node_modules/

# Env files (none used today, defensive)
.env
.env.local

# Logs
*.log


# Playwright CLI artifacts (snapshots, console logs)
.playwright-cli/
